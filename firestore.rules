rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
                    && incoming().userId == userId
                    && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
                    && incoming().userId == userId
                    && incoming().createdAt == existing().createdAt
                    && incoming().diff(existing()).affectedKeys().hasOnly(['settings', 'displayName']);
    }

    match /analysis_reports/{reportId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
                    && isOwner(incoming().userId)
                    && isValidId(reportId)
                    && incoming().timestamp == request.time;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /logic_rules/{ruleId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable through Server/Cloud Functions or Admin Dashboard (not configured here)
    }
  }
}
